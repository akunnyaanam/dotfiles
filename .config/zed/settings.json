{
  "preferred_line_length": 100,
  "soft_wrap": "bounded",
  "icon_theme": "Catppuccin Frappé",
  "ui_font_family": "JetBrainsMono Nerd Font",
  "agent": {
    "default_width": 550.0,
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "left",
    "default_width": 550.0,
    "button": false,
  },
  "debugger": {
    "dock": "right",
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
    "default_width": 550.0,
  },
  "outline_panel": {
    "indent_size": 15.0,
    "default_width": 550.0,
    "dock": "right",
  },
  "project_panel": {
    "indent_guides": {
      "show": "never",
    },
    "hide_root": false,
    "scrollbar": {
      "horizontal_scroll": true,
      "show": "never",
    },
    "indent_size": 10.0,
    "entry_spacing": "standard",
    "default_width": 550.0,
    "dock": "right",
  },
  "terminal": {
    "shell": {
      "program": "zsh",
    },
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "vim_mode": true,
  "vim": {
    "default_mode": "normal",
    "use_system_clipboard": "never",
    "use_smartcase_find": true,
    "use_regex_search": true,
    "gdefault": true,
    "toggle_relative_line_numbers": true,
    "highlight_on_yank_duration": 50,
  },
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  "scrollbar": { "show": "auto" },
  "vertical_scroll_margin": 8,
  "ui_font_size": 18.0,
  "buffer_font_size": 18.0,
  "prettier": {
    "allowed": true,
  },
  "languages": {
    "PHP": {
      "language_servers": ["intelephense", "!phpactor", "!phptools", "..."],
      "tab_size": 4,
      "hard_tabs": false,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "bash",
          "arguments": [
            "-c",
            "cat > {buffer_path} && ./vendor/bin/pint --quiet {buffer_path} && cat {buffer_path}",
          ],
        },
      },
    },
  },
}
